      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Location)",
      "PowerShell(npm *)",
      "PowerShell(py *)",
      "PowerShell(New-Item *)",
      "PowerShell(& \"C:\\\\Users\\\\NorthWhite\\\\Desktop\\\\Project\\\\Youtube playlist\\\\backend\\\\venv\\\\Scripts\\\\pip.exe\" install django djangorestframework django-cors-headers)",
      "PowerShell($venvPy = \"C:\\\\Users\\\\NorthWhite\\\\Desktop\\\\Project\\\\Youtube playlist\\\\backend\\\\venv\\\\Scripts\\\\python.exe\"; Set-Location \"C:\\\\Users\\\\NorthWhite\\\\Desktop\\\\Project\\\\Youtube playlist\\\\backend\"; & $venvPy -m django startproject config .; & $venvPy manage.py startapp api)",
      "Bash(./venv/Scripts/python manage.py runserver)",
      "Bash(curl -s http://localhost:8000/api/)",
      "Bash(npm install *)",
      "Bash(npx tsc *)",
      "Bash(git *)",
      "Bash(Set-Location *)",
      "PowerShell(Set-Location *)",
      "Bash(npm ls *)",
      "PowerShell(npx tsc -b --noEmit 2>&1)",
      "PowerShell(Get-ChildItem -Path \"C:\\\\Users\\\\NorthWhite\\\\Desktop\\\\Project\\\\Youtube playlist\" -Recurse -Depth 2 | Where-Object { $_.Name -ne '.git' } | Select-Object FullName | Out-String -Width 500)",
      "PowerShell(Get-ChildItem -Path \"C:\\\\Users\\\\NorthWhite\\\\Desktop\\\\Project\\\\Youtube playlist\\\\frontend\\\\src\" -Recurse -Depth 3 | Where-Object { -not $_.PSIsContainer } | Select-Object FullName)",
      "Bash(New-Item *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -c \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\notify.wav').PlaySync()\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -c \"[System.Media.SystemSounds]::Hand.Play()\""
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -c \"[System.Media.SystemSounds]::Asterisk.Play()\""
          }
        ]
      }
    ]
  }
}
